# Archivo de Configuración - Variables de Entorno
# COPIAR COMO: .env (El archivo actual es .env.example como referencia)
# IMPORTANTE: NUNCA SUBIR A GIT, MANTENER LOCAL

# Base de Datos
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=estetica_db

# Aplicación
APP_URL=http://localhost/estetica
APP_ENV=development
APP_DEBUG=true

# Zona Horaria
TIMEZONE=America/Mexico_City

# Email (Mailgun)
MAILGUN_API_KEY=
MAILGUN_DOMAIN=

# Email (SendGrid)
SENDGRID_API_KEY=

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-email@gmail.com
SMTP_PASS=tu-contraseña-app
SMTP_FROM=estética@example.com

# Stripe
STRIPE_PUBLIC_KEY=pk_test_
STRIPE_SECRET_KEY=sk_test_
STRIPE_CURRENCY=mxn

# Google Calendar (Opcional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Twilio SMS (Opcional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE=

# Modo de Pago (simulado|stripe|paypal)
PAYMENT_MODE=simulado

# Seguridad
CSRF_TOKEN_ENABLED=true
SESSION_TIMEOUT=3600
MAX_LOGIN_ATTEMPTS=5

# Logs
LOG_LEVEL=error
LOG_FILE=logs/app.log

# En producción, cambiar:
APP_ENV=production
APP_DEBUG=false
LOG_LEVEL=warning
